# ============================================================
# CS2 Automated Server Setup & Management Tool — .gitignore
# ============================================================


# ------------------------------------------------------------
# Editor / tooling config — local only
# ------------------------------------------------------------
.claude/


# ------------------------------------------------------------
# CS2 Server & SteamCMD — never commit game binaries (30+ GB)
# ------------------------------------------------------------
steamcmd/
cs2_server/
game/
*.exe
*.dll
*.so
*.sh


# ------------------------------------------------------------
# Runtime state & lock files generated during operation
# ------------------------------------------------------------
install_state.json
cs2-plugins.lock


# ------------------------------------------------------------
# Snapshot archives created by the rollback engine
# ------------------------------------------------------------
.snapshots/


# ------------------------------------------------------------
# Temporary files from atomic writes and downloads
# ------------------------------------------------------------
*.tmp
*.zip
*.tar.gz
*.tar.xz
*.7z


# ------------------------------------------------------------
# Secrets — GSLT tokens, API keys, RCON passwords
# ------------------------------------------------------------
.env
.env.local
.env.*.local
*.secret
secrets.json


# ------------------------------------------------------------
# Log files — may contain sensitive console output
# ------------------------------------------------------------
*.log
logs/
console.log


# ------------------------------------------------------------
# Python — virtual environments
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/


# ------------------------------------------------------------
# Python — bytecode and caches
# ------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.egg-info/
dist/
build/
.eggs/


# ------------------------------------------------------------
# IDE — JetBrains (PyCharm, etc.)
# ------------------------------------------------------------
.idea/


# ------------------------------------------------------------
# IDE — Visual Studio Code
# ------------------------------------------------------------
.vscode/


# ------------------------------------------------------------
# IDE — Vim / Neovim swap files
# ------------------------------------------------------------
*.swp
*.swo
*~


# ------------------------------------------------------------
# OS — macOS
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride


# ------------------------------------------------------------
# OS — Windows
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
